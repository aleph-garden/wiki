#################################################################
# Chat — the transcript of Session_042 so far
#################################################################
:Session_042_msg1 a aleph:ChatMessage ;
    aleph:position 1 ; aleph:speaker "user" ;
    aleph:body "i want to map out how game theory shows up across fields — biology, econ, politics" ;
    prov:wasGeneratedBy :Session_042 ;
    prov:generatedAtTime "2026-04-12T14:23:01Z"^^xsd:dateTime .

:Session_042_msg2 a aleph:ChatMessage ;
    aleph:position 2 ; aleph:speaker "agent" ;
    aleph:body "Good seed. I'll anchor the concept and pull its direct neighbors from your existing graph first. You already have Nash Equilibrium (created in Session 38) and a stub for von Neumann — I'll link them as :derivedFrom and :wasAttributedTo." ;
    prov:wasGeneratedBy :Session_042 ;
    prov:generatedAtTime "2026-04-12T14:23:34Z"^^xsd:dateTime .

:Session_042_msg3 a aleph:ChatMessage ;
    aleph:position 3 ; aleph:speaker "agent" ;
    aleph:hint "suggestion" ;
    aleph:body "Adding Prisoner's Dilemma · Evolutionary Game Theory · Mechanism Design. Should I import the Cold War branch (deterrence, MAD)? It connects to your Politics cluster." ;
    prov:wasGeneratedBy :Session_042 ;
    prov:generatedAtTime "2026-04-12T14:28:11Z"^^xsd:dateTime .

:Session_042_msg4 a aleph:ChatMessage ;
    aleph:position 4 ; aleph:speaker "user" ;
    aleph:body "yes, and link information theory" ;
    prov:wasGeneratedBy :Session_042 ;
    prov:generatedAtTime "2026-04-12T14:41:02Z"^^xsd:dateTime .

:Session_042_msg5 a aleph:ChatMessage ;
    aleph:position 5 ; aleph:speaker "agent" ;
    aleph:hint "insight" ;
    aleph:body "Linked. :GameTheory skos:related :InformationTheory. Note the bridge: both formalize uncertainty under constraint — that's why your earlier note on Shannon resonates here." ;
    prov:wasGeneratedBy :Session_042 ;
    prov:generatedAtTime "2026-04-12T14:41:38Z"^^xsd:dateTime .

#################################################################
# View — the captured "Point" answer state
#################################################################
:View_gt_to_biology a aleph:View ;
    rdfs:label "How does game theory reach biology?"@en ;
    aleph:question "How does game theory reach biology?" ;
    aleph:trail ( "Strategy & Games" "Mathematics" "Logic" ) ;
    aleph:path  ( :GameTheory :EvolutionaryGameTheory :Evolution ) ;

    aleph:edgeNote [
        aleph:from :GameTheory ; aleph:to :EvolutionaryGameTheory ;
        rdfs:label "narrows to" ;
        aleph:cite "session 035" ] ;
    aleph:edgeNote [
        aleph:from :EvolutionaryGameTheory ; aleph:to :Evolution ;
        rdfs:label "shares assumptions with" ;
        aleph:cite "session 042" ] ;

    aleph:pathNote [
        aleph:atConcept :EvolutionaryGameTheory ;
        aleph:noteText "EGT replaces \"rational agent\" with\n\"replicating strategy.\"" ] ;
    aleph:pathNote [
        aleph:atConcept :Evolution ;
        aleph:noteText "ESS (Maynard Smith, 1973) is the\nbridge term. Citable." ] ;

    aleph:suggestion [ aleph:target :ESS         ; aleph:reason "follows from path" ] ;
    aleph:suggestion [ aleph:target :Cooperation ; aleph:reason "related to PD" ] ;
    aleph:suggestion [ aleph:target :JohnNash    ; aleph:reason "authored equilibrium" ] ;

    prov:wasGeneratedBy :Session_042 ;
    prov:generatedAtTime "2026-04-12T14:48:09Z"^^xsd:dateTime .


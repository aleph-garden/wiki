# ============================================================
# Query: activeSession
# ============================================================
#
# Resolves the currently active session — the most recently
# started aleph:AlephSession. Drives chat-input target and
# the in-view "this session" highlight ring.
#
# Params:
#   (none)
#
# Returns:
#   ?session (NamedNode) — IRI of the active aleph:AlephSession.
#
# Example:
#   useActiveSessionId()
# ============================================================

SELECT ?session WHERE {
  ?session a aleph:AlephSession ;
           prov:startedAtTime ?startedAt .
}
ORDER BY DESC(?startedAt)
LIMIT 1

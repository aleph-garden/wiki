@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix aleph: <https://vocab.aleph.wiki/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://vocab.aleph.wiki/shapes> a sh:ShapesGraph ;
    rdfs:label "Aleph Wiki SHACL Shapes"@en ;
    rdfs:comment "SHACL constraints for validating the Aleph Wiki knowledge graph, ensuring proper provenance tracking and data integrity."@en .

#################################################################
#    Concept Shapes
#################################################################

aleph:ConceptShape a sh:NodeShape ;
    sh:targetClass aleph:Concept ;
    rdfs:label "Concept Shape"@en ;
    rdfs:comment "Validates that concepts have proper provenance metadata."@en ;

    # Every concept MUST have a generatedBy linking to a session
    sh:property [
        sh:path prov:wasGeneratedBy ;
        sh:name "generated by" ;
        sh:description "Every concept must be linked to the session that generated it" ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:class aleph:AlephSession ;
        sh:message "Concept must have exactly one prov:wasGeneratedBy property linking to an AlephSession" ;
        sh:severity sh:Violation
    ] ;

    # Every concept MUST have a generation timestamp
    sh:property [
        sh:path prov:generatedAtTime ;
        sh:name "generated at time" ;
        sh:description "Every concept must have a timestamp of when it was generated" ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:dateTime ;
        sh:message "Concept must have exactly one prov:generatedAtTime with datatype xsd:dateTime" ;
        sh:severity sh:Violation
    ] ;

    # Every concept SHOULD have a preferred label
    sh:property [
        sh:path <http://www.w3.org/2004/02/skos/core#prefLabel> ;
        sh:name "preferred label" ;
        sh:description "Concepts should have a human-readable label" ;
        sh:minCount 1 ;
        sh:datatype rdf:langString ;
        sh:message "Concept should have at least one skos:prefLabel" ;
        sh:severity sh:Warning
    ] ;

    # Every concept MAY be attributed to an agent
    sh:property [
        sh:path prov:wasAttributedTo ;
        sh:name "attributed to" ;
        sh:description "Concepts may be attributed to an agent (user or software)" ;
        sh:maxCount 1 ;
        sh:class prov:Agent ;
        sh:severity sh:Info
    ] .

#################################################################
#    Session Shapes
#################################################################

aleph:SessionShape a sh:NodeShape ;
    sh:targetClass aleph:AlephSession ;
    rdfs:label "Session Shape"@en ;
    rdfs:comment "Validates that sessions have proper temporal and agent metadata."@en ;

    # Every session MUST have a start time
    sh:property [
        sh:path prov:startedAtTime ;
        sh:name "started at time" ;
        sh:description "Every session must have a start timestamp" ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:dateTime ;
        sh:message "Session must have exactly one prov:startedAtTime with datatype xsd:dateTime" ;
        sh:severity sh:Violation
    ] ;

    # Every session SHOULD have an end time (may be ongoing)
    sh:property [
        sh:path prov:endedAtTime ;
        sh:name "ended at time" ;
        sh:description "Sessions should have an end timestamp when completed" ;
        sh:maxCount 1 ;
        sh:datatype xsd:dateTime ;
        sh:message "Session should have at most one prov:endedAtTime with datatype xsd:dateTime" ;
        sh:severity sh:Warning
    ] ;

    # Every session MUST be associated with at least one agent
    sh:property [
        sh:path prov:wasAssociatedWith ;
        sh:name "associated with agent" ;
        sh:description "Every session must be associated with at least one agent" ;
        sh:minCount 1 ;
        sh:class prov:Agent ;
        sh:message "Session must be associated with at least one prov:Agent via prov:wasAssociatedWith" ;
        sh:severity sh:Violation
    ] ;

    # Session end time must be after start time (if present)
    sh:sparql [
        sh:message "Session end time must be after start time" ;
        sh:severity sh:Violation ;
        sh:select """
            PREFIX prov: <http://www.w3.org/ns/prov#>
            SELECT $this
            WHERE {
                $this prov:startedAtTime ?start ;
                      prov:endedAtTime ?end .
                FILTER (?end <= ?start)
            }
        """
    ] .

#################################################################
#    Agent Shapes
#################################################################

aleph:AgentShape a sh:NodeShape ;
    sh:targetClass prov:Agent ;
    rdfs:label "Agent Shape"@en ;
    rdfs:comment "Validates agent metadata."@en ;

    # Every agent SHOULD have a label
    sh:property [
        sh:path rdfs:label ;
        sh:name "label" ;
        sh:description "Agents should have a human-readable label" ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:message "Agent should have at least one rdfs:label" ;
        sh:severity sh:Warning
    ] .

aleph:SoftwareAgentShape a sh:NodeShape ;
    sh:targetClass prov:SoftwareAgent ;
    rdfs:label "Software Agent Shape"@en ;
    rdfs:comment "Validates software agent delegation."@en ;

    # Software agents SHOULD declare who they act on behalf of
    sh:property [
        sh:path prov:actedOnBehalfOf ;
        sh:name "acted on behalf of" ;
        sh:description "Software agents should declare the person they represent" ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:class prov:Person ;
        sh:message "Software agent should have one prov:actedOnBehalfOf linking to a prov:Person" ;
        sh:severity sh:Warning
    ] .

#################################################################
#    Provenance Chain Validation
#################################################################

aleph:ProvenanceChainShape a sh:NodeShape ;
    sh:targetClass prov:Entity ;
    rdfs:label "Provenance Chain Shape"@en ;
    rdfs:comment "Validates that derived entities maintain proper provenance chains."@en ;

    # If an entity is derived from another, it must have a generation time
    sh:sparql [
        sh:message "Derived entities must have a generation timestamp" ;
        sh:severity sh:Violation ;
        sh:select """
            PREFIX prov: <http://www.w3.org/ns/prov#>
            SELECT $this
            WHERE {
                $this prov:wasDerivedFrom ?source .
                FILTER NOT EXISTS { $this prov:generatedAtTime ?time }
            }
        """
    ] ;

    # If an entity is a revision, the generation time should be after the original
    sh:sparql [
        sh:message "Revision must be generated after the original entity" ;
        sh:severity sh:Warning ;
        sh:select """
            PREFIX prov: <http://www.w3.org/ns/prov#>
            SELECT $this
            WHERE {
                $this prov:wasRevisionOf ?original ;
                      prov:generatedAtTime ?thisTime .
                ?original prov:generatedAtTime ?originalTime .
                FILTER (?thisTime <= ?originalTime)
            }
        """
    ] .
